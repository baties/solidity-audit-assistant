# ============================================================
# SolidityGuard AI — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001                                # Express API port (Next.js runs on 3000)
NEXT_PUBLIC_API_URL=http://localhost:3001 # Used by the frontend to reach the API in dev
FRONTEND_URL=http://localhost:3000        # CORS origin for Express

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://solidityguard:password@localhost:5432/solidityguard
POSTGRES_DB=solidityguard
POSTGRES_USER=solidityguard
POSTGRES_PASSWORD=changeme_in_production

# ── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...             # REQUIRED — get from https://console.anthropic.com

# ── Blockchain Data ──────────────────────────────────────────
ETHERSCAN_API_KEY=                       # REQUIRED for address scans — get from https://etherscan.io/apis
ETHERSCAN_BASE_URL=https://api.etherscan.io/api

# ── GitHub Source Fetching ───────────────────────────────────
GITHUB_TOKEN=ghp_...                     # OPTIONAL — increases rate limit from 60 to 5000 req/hr

# ── Auth (Phase 3 — leave empty until Phase 3 is implemented) ──
NEXTAUTH_SECRET=                         # Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug                          # debug (dev) | info (prod)

INTERNAL_API_URL=http://localhost:3001  # Server-side Next.js → Express (same container in Docker)
