# ============================================================
# SolidityGuard AI — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001                                # Express API port (Next.js runs on 3000)
NEXT_PUBLIC_API_URL=http://localhost:3001 # Used by the frontend to reach the API in dev
FRONTEND_URL=http://localhost:3000        # CORS origin for Express

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://solidityguard:password@localhost:5432/solidityguard
POSTGRES_DB=solidityguard
POSTGRES_USER=solidityguard
POSTGRES_PASSWORD=changeme_in_production

# ── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...             # REQUIRED — get from https://console.anthropic.com

# ── Blockchain Data ──────────────────────────────────────────
# ETHERSCAN_API_KEY is the fallback for any chain that doesn't have a dedicated key set.
# Add chain-specific keys to get higher rate limits and avoid sharing quota across chains.
ETHERSCAN_API_KEY=                       # REQUIRED — fallback for all chains — https://etherscan.io/apis
POLYGONSCAN_API_KEY=                     # OPTIONAL — Polygon (matic) — https://polygonscan.com/apis
ARBISCAN_API_KEY=                        # OPTIONAL — Arbitrum One  — https://arbiscan.io/apis
OPTIMISM_ETHERSCAN_API_KEY=              # OPTIONAL — Optimism      — https://optimistic.etherscan.io/apis
BASESCAN_API_KEY=                        # OPTIONAL — Base          — https://basescan.org/apis
BSCSCAN_API_KEY=                         # OPTIONAL — BNB Chain     — https://bscscan.com/apis

# ── GitHub Source Fetching ───────────────────────────────────
GITHUB_TOKEN=ghp_...                     # OPTIONAL — increases rate limit from 60 to 5000 req/hr

# ── Auth (Phase 3 — leave empty until Phase 3 is implemented) ──
NEXTAUTH_SECRET=                         # Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug                          # debug (dev) | info (prod)

INTERNAL_API_URL=http://localhost:3001  # Server-side Next.js → Express (same container in Docker)
