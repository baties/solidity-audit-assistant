{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "app", "components", "lib", "dist"]
}
